# Per-Dockerfile ignore for the storefront build (BuildKit honours
# `<Dockerfile>.dockerignore` over any repo-root `.dockerignore`).

# Heavy / regenerated — always reinstalled or rebuilt in the image.
**/node_modules/
**/.next/
**/dist/
**/coverage/
**/*.tsbuildinfo

# VCS / tooling / local env.
.git/
.idea/
**/*.log
**/.env
**/.env.local
**/.env.*.local
.claude/

# Tutorial material — not part of the app build.
tutorial/

# The MCP connector (created during the tutorial) is a separate service/image.
mcp/
