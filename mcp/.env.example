# ── Northwind MCP connector ──────────────────────────────────────────────────
# Copy to `.env` (the dev script loads it automatically via tsx).

# Port the MCP server listens on.
MCP_PORT=3011

# Base URL of the Northwind storefront's REST API (the Next.js app).
NORTHWIND_API_URL=http://localhost:3010

# ── Hub bind (this server registers sessions with the hub) ───────────────────
# The hub's URL and an admin capability key with the `auth:bind` scope
# (mint via the Dioschub admin portal — API keys → capability key).
DIOSC_HUB_URL=http://localhost:3333
DIOSC_HUB_API_KEY=

# ── Token issuing ────────────────────────────────────────────────────────────
# Secret for signing the HS256 session JWTs this server issues at bind time.
# Set a strong value in any real deployment; blank = insecure dev fallback.
MCP_JWT_SECRET=

# Shared secret the storefront must present on POST /auth/bind (header
# `x-bind-secret`). Must match the storefront's MCP_BIND_SECRET. Blank =
# unauthenticated bind endpoint (dev only).
MCP_BIND_SECRET=
