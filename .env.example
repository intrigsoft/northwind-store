# ── Northwind storefront ─────────────────────────────────────────────────────
# Copy to `.env.local` and fill in. Everything has a sensible default for a
# pure-frontend run; the Dioschub values are only needed to embed the assistant.

# ── Dioschub assistant (client-side, exposed to the browser) ─────────────────
# Base URL of the Dioschub backend (the diosc-ai hub). Defaults to the repo's
# dev port. The assistant kit loads from here and opens its WebSocket here.
NEXT_PUBLIC_DIOSC_BACKEND_URL=http://localhost:3333

# Embed API key issued by the Dioschub admin portal. Without it the kit loads
# in an unstyled/unentitled state. Leave blank to run the store with no assistant.
NEXT_PUBLIC_DIOSC_API_KEY=

# Assistant ID to converse with (from the Dioschub admin portal). Optional.
NEXT_PUBLIC_DIOSC_ASSISTANT_ID=

# ── Assistant bind (server-side only — never exposed to the browser) ─────────
# The host-side /api/diosc/bind endpoint hands the visitor's identity + session
# cookie to OUR MCP server, which mints the JWT the hub uses as auth artifact.
# The storefront no longer talks to the hub, and holds no hub credentials.
NORTHWIND_MCP_URL=http://localhost:3011
# Must match the MCP server's MCP_BIND_SECRET (see mcp/.env.example).
MCP_BIND_SECRET=
# Role the storefront's users map to inside Dioschub (a Role id from the hub).
DIOSC_HUB_ROLE_ID=role-default
